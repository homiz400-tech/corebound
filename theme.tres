[gd_resource type="Theme" resource_format=3 uid="uid://bcoreboundtheme1"]

[resource]
default_font_size = 22

# Flat / cel-blocky palette: vibrant, high-contrast, readable on phone.
# Surface = warm sky, bands = earthy, core = hot. Accent = cyan for UI.
constants/Margin/MarginContainer = 8

# Label: bold, light text on dark
Label/colors/default_color = Color(0.95, 0.95, 0.98, 1)
Label/font_sizes/font_size = 22

# Button: chunky blocky with dark outline feel
Button/colors/font_color = Color(0.07, 0.05, 0.12, 1)
Button/colors/font_hover_color = Color(0.07, 0.05, 0.12, 1)
Button/styles/normal = SubResource("ButtonNormal")
Button/styles/hover = SubResource("ButtonHover")
Button/styles/pressed = SubResource("ButtonPressed")

